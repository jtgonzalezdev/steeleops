APP_ENV=production
PORT=10000
HOST=0.0.0.0
SECRET_KEY=replace-with-a-long-random-secret
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME
SESSION_COOKIE_SECURE=1
SESSION_TTL_HOURS=24
MAX_UPLOAD_MB=8
APP_BASE_URL=https://your-domain.example.com

# Branding defaults keep SteeleOps as the product while allowing future white-label overrides.
PRODUCT_SHORT_NAME=SteeleOps
PRODUCT_FULL_NAME=SteeleOps Control Center
PROVIDER_BRAND_NAME=Steele Security Services
PROVIDER_POWERED_BY_TEXT=Powered by Steele Security Services

# Storage
STORAGE_BACKEND=local
UPLOAD_DIR=/mnt/data/uploads
RENDER_DISK_PATH=/mnt/data
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_BASE_URL=

# Password reset
RESET_TOKEN_HOURS=2
ALLOW_BROWSER_PASSWORD_RESET_LINKS=0
